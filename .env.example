# ─── Database ──────────────────────────────────────────
DB_URL=jdbc:postgresql://localhost:5432/dersplatform
DB_USER=dersplatform
DB_PASSWORD=dersplatform

# ─── Redis ─────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── JWT ────────────────────────────────────────────────
JWT_SECRET=<generate with: openssl rand -base64 32>

# ─── CORS ──────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── Mail (Amazon SES) ─────────────────────────────────
# AWS credentials are resolved through the standard AWS credential chain.
# In EKS, use the backend IRSA role created by Terraform; never put AWS keys here.
AWS_REGION=eu-north-1
MAIL_FROM_EMAIL=no-reply@ogret.io

# ─── Twilio (SMS) ──────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ─── Spring Profile ────────────────────────────────────
# SPRING_PROFILES_ACTIVE=dev

# ─── Mobile App (Expo) ────────────────────────────────
# EXPO_PUBLIC_API_URL=http://localhost:8080/api/v1
