# Local Docker development requires no .env file. Run:
#   docker compose up --build
#
# This file documents optional integration settings and the values required by
# docker-compose.prod.yml. Do not use these placeholders as production secrets.

# ─── Production database / Redis ──────────────────────
DB_PASSWORD=
REDIS_PASSWORD=

# ─── Production JWT (unique, at least 48 characters) ──
JWT_SECRET=

# ─── Production public URLs ───────────────────────────
CORS_ORIGINS=https://ogret.io,https://www.ogret.io
APP_BASE_URL=https://ogret.io

# ─── Production object storage ────────────────────────
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=
AWS_S3_PUBLIC_URL=https://files.ogret.io

# ─── Transactional mail (optional in every profile) ───
# EMAIL_ENABLED=false needs no provider credentials. When enabled in production,
# use a verified sender and AWS workload identity / credential chain.
EMAIL_ENABLED=false
AWS_REGION=eu-north-1
MAIL_FROM_EMAIL=

# ─── Optional SMS integration ─────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ─── Optional mobile app development ──────────────────
# EXPO_PUBLIC_API_URL=http://localhost:8080/api/v1
